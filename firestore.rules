rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check if user is logged in
    function isSignedIn() {
      return request.auth != null;
    }

    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Rules for users collection
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Rules for api_keys collection
    match /api_keys/{apiKey} {
      // Client writes/deletes to their own api key
      allow create, update: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      // Server or client can read/lookup the specific API key
      allow read: if true;
    }

    // Rules for transactions collection
    match /transactions/{txId} {
      // Client writes to their own transactions
      allow create, update, delete: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      // Server or client can read/lookup transactions
      allow read: if true;
    }
  }
}
